{
  "manifest_version": 3,
  "name": "MAX Channel Exporter",
  "version": "1.3.5",
  "description": "Экспорт постов публичных MAX-каналов в CSV или JSON.",
  "permissions": [
    "activeTab",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://max.ru/*",
    "https://web.max.ru/*"
  ],
  "action": {
    "default_title": "Export MAX posts",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://max.ru/*",
        "https://web.max.ru/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}